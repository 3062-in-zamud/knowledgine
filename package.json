{
  "name": "knowledgine",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Developer Knowledge Infrastructure - Extract structured knowledge from your codebase for AI coding tools",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:run",
    "prepare": "husky",
    "benchmark:longmemeval": "pnpm --filter @knowledgine/core exec vitest run --config vitest.benchmark.config.ts tests/benchmark/longmemeval/longmemeval-full.test.ts",
    "benchmark:longmemeval:download": "pnpm --filter @knowledgine/core exec tsx tests/benchmark/longmemeval/download-dataset.ts",
    "benchmark:longmemeval:quick": "pnpm --filter @knowledgine/core run test:run tests/benchmark/longmemeval/longmemeval.test.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
