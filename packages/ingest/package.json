{
  "name": "@knowledgine/ingest",
  "version": "0.6.3",
  "description": "Plugin-based knowledge ingestion engine for knowledgine. Supports Git history, GitHub, Obsidian, and Claude Sessions.",
  "keywords": [
    "knowledgine",
    "ingest",
    "knowledge-management",
    "plugin",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/3062-in-zamud/knowledgine.git",
    "directory": "packages/ingest"
  },
  "homepage": "https://github.com/3062-in-zamud/knowledgine#readme",
  "bugs": {
    "url": "https://github.com/3062-in-zamud/knowledgine/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@knowledgine/core": "workspace:*",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/picomatch": "^4.0.2",
    "better-sqlite3": "^11.0.0"
  }
}
