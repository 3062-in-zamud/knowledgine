{
  "name": "@knowledgine/cli",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "knowledgine": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@knowledgine/core": "workspace:*",
    "@knowledgine/ingest": "workspace:*",
    "@knowledgine/mcp-server": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "log-symbols": "^7.0.1",
    "ora": "^9.3.0",
    "smol-toml": "^1.6.0"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "description": "CLI for indexing markdown files and serving MCP knowledge tools",
  "mcpName": "io.github.3062-in-zamud/knowledgine",
  "keywords": [
