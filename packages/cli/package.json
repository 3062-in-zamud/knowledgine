{
  "name": "@knowledgine/cli",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "knowledgine": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@knowledgine/core": "workspace:*",
    "@knowledgine/mcp-server": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3"
  },
  "files": [
    "dist"
  ],
  "description": "CLI for indexing markdown files and serving MCP knowledge tools",
  "keywords": [
    "knowledgine",
    "cli",
    "mcp",
    "knowledge",
    "indexer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/3062-in-zamud/knowledgine.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/3062-in-zamud/knowledgine#readme",
  "bugs": {
    "url": "https://github.com/3062-in-zamud/knowledgine/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
